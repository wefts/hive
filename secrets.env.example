# SECRET keys (values empty). Copy to `secrets.env`, fill, and keep it OUT of
# every repo and every sync. `secrets.env` is excluded by deploy.sh and lives
# in exactly one place per machine (workspace root). Never echo into logs/tmp.
#
# On Spark you MAY instead point SWARM_SECRETS_ENV at an existing outside-repo
# file rather than copying values anywhere.

# --- Confluence ---
CONFLUENCE_URL=
CONFLUENCE_USER=
CONFLUENCE_TOKEN=

# --- MediaWiki ---
WIKI_URL=
WIKI_USER=
WIKI_USER_TOKEN=
WIKI_ALT_USERNAME=
WIKI_ALT_TOKEN=
