# SECRET keys (values empty). Copy to `secrets.env`, fill, and keep it OUT of
# every repo and every sync. `secrets.env` is excluded by deploy.sh and lives
# in exactly one place per machine (workspace root). Never echo into logs/tmp.
#
# On Spark you MAY instead point SWARM_SECRETS_ENV at an existing outside-repo
# file rather than copying values anywhere.

# --- Confluence ---
CONFLUENCE_URL=
CONFLUENCE_USER=
CONFLUENCE_TOKEN=

# --- MediaWiki ---
WIKI_URL=
WIKI_USER=
WIKI_USER_TOKEN=
WIKI_ALT_USERNAME=
WIKI_ALT_TOKEN=

# --- web_channel (P1 identity) ---
# Local dev uses safe compose fallbacks; set these for a shared/prod deploy.
# SESSION_SECRET signs the session cookie (which carries authorization) — MUST be a
# strong random value in prod; empty ⇒ the app mints an ephemeral per-boot key.
WEB_CHANNEL_SESSION_SECRET=
# The Keycloak OIDC confidential-client secret (real value from vault.galaxy.intranet
# when pointing at sso.smile.eu/realms/Smile; local dev uses the realm-import default).
WEB_CHANNEL_OIDC_SECRET=
# Keycloak admin password (local dev defaults to admin/admin in compose).
KEYCLOAK_ADMIN_PASSWORD=
