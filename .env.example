# Hive config (NON-secret). Copy to `.env` and adjust per machine.
# docker-compose reads this automatically from the hive root.
# `.env` is per-machine and NEVER synced; only this `.example` travels.

# --- Postgres (kernel substrate) ---
SWARM_DB_USER=swarm
SWARM_DB_PASSWORD=swarm
SWARM_DB_NAME=swarm_dev
SWARM_DB_PORT=5432

# --- Core API (kernel gRPC, published on the host) ---
SWARM_CORE_API_PORT=50061

# --- Registry tier ---------------------------------------------------------
# Where base/runtime images are pulled from. Precedence by intent:
#   local mirror (localhost:5000, fully offline — see docker-compose.offline.yml)
#   → Smile public aliases (defaults below; safe to commit; flap-resistant)
#   → upstream (Docker Hub / DHI).
# Digests are content-addressed, so the same pin resolves on any mirror.
HUB_REGISTRY=dockerhub.smile.fr
DHI_REGISTRY=dhi.smile.fr

# --- Ollama (containerized GPU service) ------------------------------------
# Ollama now runs IN the stack (GPU), reached over the compose network.
# (The old host-Ollama mode would be http://host.docker.internal:11434.)
OLLAMA_BASE_URL=http://ollama:11434
# Host model store, bind-mounted read-only into the ollama container (238 GB,
# not re-downloaded). Local and Spark differ only by this path if at all.
OLLAMA_MODELS_DIR=/usr/share/ollama/.ollama/models

# --- Plugin / data roots ---
# Local and Spark differ ONLY by these values.
SWARM_PLUGINS_DIR=./plugins
SWARM_DATA_DIR=./data

# --- Secrets pointer ---
# Path to the secrets env file (loaded by plugins that need creds).
# NEVER point this into the repo or a synced location.
#   local : ./secrets.env
#   Spark : $HOME/Swarm/hive/secrets.env  (or an existing outside-repo .env)
SWARM_SECRETS_ENV=./secrets.env
